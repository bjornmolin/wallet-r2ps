FROM rust:1.94-bookworm@sha256:6ae102bdbf528294bc79ad6e1fae682f6f7c2a6e6621506ba959f9685b308a55 AS builder

RUN apt-get update && apt-get install -y \
    zlib1g zlib1g-dev \
    cmake \
    libssl-dev \
    libsasl2-dev \
    libzstd-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY hsm-common ./hsm-common
COPY hsm-worker ./hsm-worker
COPY wallet-bff ./wallet-bff
COPY integration-load-tests ./integration-load-tests

RUN cargo build --release -p wallet-bff

# Lets reusable-ci's extract.binary export the built binary.
FROM scratch AS export-binary
COPY --from=builder /app/target/release/wallet-bff /wallet-bff

FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y \
    zlib1g \
    libssl3 \
    libsasl2-2 \
    libzstd1 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m appuser
USER appuser

COPY --from=builder /app/target/release/wallet-bff /wallet-bff

EXPOSE 8088

CMD ["/wallet-bff"]
